<?xml version="1.0" encoding="UTF-8"?>
<style-scheme id="space-kde-slate-soft-high-contrast" _name="Space KDE (Soft High Contrast)" version="1.0">
  <author>Eliver Lara / Jonathon</author>
  <_description>Midnight theme with softened neon green and orange for reduced glare</_description>

  <!-- Space-KDE Soft High-Contrast Palette -->
  <color name="space-bg"      value="#121b21"/> <!-- Deep Midnight Blue -->
  <color name="space-fg"      value="#ffffff"/> <!-- Pure White Text -->
  <color name="space-line"    value="#1a252b"/> 
  <color name="space-sel"     value="#24333d"/> 
  
  <color name="space-violet"  value="#bb9af7"/> <!-- Softened Electric Violet -->
  <color name="space-blue"    value="#7aa2f7"/> <!-- Softened Sky Blue -->
  <color name="space-cyan"    value="#7dcfff"/> <!-- Softened Cyan -->
  <color name="space-amber"   value="#e0af68"/> <!-- Warm Honey (Replaces bright Amber) -->
  <color name="space-orange"  value="#ff9e64"/> <!-- Soft Peach-Orange (Softer than #ff8c00) -->
  <color name="space-green"   value="#9ece6a"/> <!-- Sage Neon (Much softer than #39ff14) -->
  <color name="space-gray"    value="#787c99"/> <!-- Muted comments -->
  <color name="space-red"     value="#f7768e"/> <!-- Softened Power Red -->

  <!-- Global Settings -->
  <style name="text"                        foreground="space-fg" background="space-bg"/>
  <style name="selection"                   background="space-sel"/>
  <style name="cursor"                      foreground="space-cyan"/>
  <style name="current-line"                background="space-line"/>
  <style name="line-numbers"                foreground="space-gray" background="#0d141a"/>
  <style name="draw-spaces"                 foreground="#3d4957"/>

  <!-- Syntax Highlighting -->
  <style name="def:comment"                 foreground="space-gray" italic="true"/>
  <style name="def:constant"                foreground="space-orange" bold="true"/>
  <style name="def:special-char"            foreground="space-amber"/>
  <style name="def:identifier"              foreground="space-cyan"/>
  <style name="def:function"                foreground="space-blue" bold="true"/>
  
  <!-- Logic & Structural Elements -->
  <style name="def:statement"               foreground="space-amber" bold="true"/>
  <style name="def:keyword"                 foreground="space-violet" bold="true"/>
  
  <!-- Green is now Sage Neon - used for types and notes -->
  <style name="def:type"                    foreground="space-green" bold="true"/>
  <style name="def:operator"                foreground="space-cyan"/>
  <style name="def:preprocessor"            foreground="space-blue"/>
  <style name="def:error"                   foreground="space-red" bold="true" underline="single"/>
  <style name="def:note"                    foreground="space-green" bold="true"/>

  <!-- Markup -->
  <style name="def:link-text"               foreground="space-blue" underline="single"/>
  <style name="def:heading"                 foreground="space-violet" bold="true"/>
</style-scheme>

