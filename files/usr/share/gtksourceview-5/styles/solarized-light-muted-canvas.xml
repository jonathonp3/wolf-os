<?xml version="1.0" encoding="UTF-8"?>
<style-scheme id="solarized-light-muted-canvas" _name="Solarized Light (Muted Canvas)" version="1.0">
  <author>Craig Russell / Jonathon/author>
  <_description>Muted ivory background for reduced brightness and eye-strain</_description>

  <!-- Solarized Palette -->
  <color name="base03"  value="#002B36"/>
  <color name="base02"  value="#073642"/>
  <color name="base01"  value="#586E75"/> <!-- Main Text (Soft Charcoal) -->
  <color name="base00"  value="#657B83"/>
  <color name="base0"   value="#839496"/>
  <color name="base1"   value="#93A1A1"/>
  <color name="base2"   value="#EEE8D5"/> <!-- Beige Highlight -->
  <color name="base3"   value="#F4F1E0"/> <!-- Muted Parchment Background -->
  
  <color name="yellow"  value="#B58900"/>
  <color name="orange"  value="#CB4B16"/>
  <color name="red"     value="#DC322F"/>
  <color name="magenta" value="#D33682"/>
  <color name="violet"  value="#6C71C4"/>
  <color name="blue"    value="#268BD2"/>
  <color name="cyan"    value="#2AA198"/>
  <color name="green"   value="#859900"/>

  <!-- Global Settings -->
  <style name="text"                        foreground="base01" background="base3"/>
  <style name="selection"                   background="#DFD8C2"/> <!-- Darker tan for selection -->
  <style name="cursor"                      foreground="base03"/>
  <style name="current-line"                background="#E9E4D0"/> <!-- Soft contrast line -->
  <style name="line-numbers"                foreground="base1" background="#E9E4D0"/>
  <style name="draw-spaces"                 foreground="#C0BCAD"/>

  <!-- Bracket Matching -->
  <style name="bracket-match"               foreground="base03" background="base2" bold="true"/>
  <style name="bracket-mismatch"            foreground="red" background="base2" bold="true"/>

  <!-- Search Matching -->
  <style name="search-match"                background="yellow" foreground="base3"/>

  <!-- Syntax Highlighting -->
  <style name="def:comment"                 foreground="base1" italic="true"/>
  <style name="def:constant"                foreground="cyan"/>
  <style name="def:identifier"              foreground="blue"/>
  <style name="def:statement"               foreground="orange" bold="true"/>
  <style name="def:keyword"                 foreground="green" bold="true"/>
  <style name="def:type"                    foreground="yellow" bold="true"/>
  <style name="def:operator"                foreground="base01"/>
  <style name="def:preprocessor"            foreground="violet"/>
  <style name="def:error"                   foreground="red" bold="true" underline="single"/>
  <style name="def:note"                    foreground="magenta" bold="true"/>

  <!-- Markup -->
  <style name="def:link-text"               foreground="blue" underline="single"/>
  <style name="def:heading"                 foreground="yellow" bold="true"/>
</style-scheme>

