<?xml version="1.0" encoding="UTF-8"?>
<style-scheme id="kimi-dark-modern" _name="Kimi (Dark Modern)" version="1.0">
  <author>Eliver Lara / Jonathon</author>
  <_description>Modern dark theme with peach and violet accents inspired by Kimi</_description>

  <!-- Kimi Palette -->
  <color name="kimi-bg"      value="#1a1c23"/> <!-- Warm Dark Charcoal -->
  <color name="kimi-fg"      value="#c4c7d1"/> <!-- Muted Silver Text -->
  <color name="kimi-line"    value="#22252e"/> <!-- Subtle Current Line -->
  <color name="kimi-sel"     value="#2d313d"/> <!-- Selection -->
  
  <color name="kimi-peach"   value="#f0a988"/> <!-- Keywords/Functions -->
  <color name="kimi-violet"  value="#c792ea"/> <!-- Statements/Markup -->
  <color name="kimi-teal"    value="#80cbc4"/> <!-- Constants -->
  <color name="kimi-cyan"    value="#89ddff"/> <!-- Identifiers -->
  <color name="kimi-blue"    value="#82aaff"/> <!-- Operators -->
  <color name="kimi-gray"    value="#5c6370"/> <!-- Comments -->
  <color name="kimi-red"     value="#f07178"/> <!-- Errors -->
  <color name="kimi-green"   value="#c3e88d"/> <!-- Strings/Notes -->

  <!-- Global Settings -->
  <style name="text"                        foreground="kimi-fg" background="kimi-bg"/>
  <style name="selection"                   background="kimi-sel"/>
  <style name="cursor"                      foreground="kimi-peach"/>
  <style name="current-line"                background="kimi-line"/>
  <style name="line-numbers"                foreground="kimi-gray" background="kimi-bg"/>
  <style name="draw-spaces"                 foreground="#3b3f51"/>

  <!-- Syntax Highlighting -->
  <style name="def:comment"                 foreground="kimi-gray" italic="true"/>
  <style name="def:constant"                foreground="kimi-teal"/>
  <style name="def:special-char"            foreground="kimi-peach"/>
  <style name="def:identifier"              foreground="kimi-cyan"/>
  <style name="def:function"                foreground="kimi-blue"/>
  <style name="def:statement"               foreground="kimi-peach" bold="true"/>
  <style name="def:keyword"                 foreground="kimi-violet"/>
  <style name="def:type"                    foreground="kimi-violet" italic="true"/>
  <style name="def:operator"                foreground="kimi-cyan"/>
  <style name="def:preprocessor"            foreground="kimi-peach"/>
  <style name="def:error"                   foreground="kimi-red" bold="true" underline="single"/>
  <style name="def:note"                    foreground="kimi-green" bold="true"/>

  <!-- Markup -->
  <style name="def:link-text"               foreground="kimi-blue" underline="single"/>
  <style name="def:heading"                 foreground="kimi-peach" bold="true"/>
</style-scheme>

