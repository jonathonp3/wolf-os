<?xml version="1.0" encoding="UTF-8"?>
<style-scheme id="solarized-light-golden-parchment" _name="Solarized Light (Golden Parchment)" version="1.0">
  <author>Craig Russell / Jonathon</author>
  <_description>Solarized light palette with a warm #F8E7B7 golden parchment background</_description>

 <!-- Solarized Palette -->
  <color name="base03"  value="#002B36"/>
  <color name="base02"  value="#073642"/>
  <color name="base01"  value="#586E75"/> <!-- Main Text (Charcoal) -->
  <color name="base00"  value="#657B83"/>
  <color name="base0"   value="#839496"/>
  <color name="base1"   value="#93A1A1"/>
  <color name="base2"   value="#EEE8D5"/> <!-- Current Line/Line Numbers -->
  <color name="base3"   value="#F8E7B7"/> <!-- Gold Background -->
  
  <color name="yellow"  value="#B58900"/>
  <color name="orange"  value="#CB4B16"/>
  <color name="red"     value="#DC322F"/>
  <color name="magenta" value="#D33682"/>
  <color name="violet"  value="#6C71C4"/>
  <color name="blue"    value="#268BD2"/>
  <color name="cyan"    value="#2AA198"/>
  <color name="green"   value="#859900"/>

  <!-- Custom Blend for the pattern -->
  <color name="base3-2-blend" value="#EADBB0"/> 

  <!-- Global Settings -->
  <style name="text"                        foreground="base01" background="base3"/>
  <style name="selection"                   foreground="base3" background="base01"/>
  <style name="cursor"                      foreground="base01"/>
  <style name="current-line"                background="#EFDEB0"/> <!-- Subtly deeper gold -->
  <style name="line-numbers"                foreground="base1" background="#EFDEB0"/>
  <style name="background-pattern"          background="base3-2-blend"/>
  <style name="draw-spaces"                 foreground="#D1C3A5"/>

  <!-- Bracket Matching -->
  <style name="bracket-match"               foreground="base3" background="base1" bold="true"/>
  <style name="bracket-mismatch"            foreground="red" background="base1" bold="true"/>

  <!-- Search Matching -->
  <style name="search-match"                foreground="base3" background="yellow"/>

  <!-- Comments -->
  <style name="def:comment"                 foreground="base1" italic="true"/>
  <style name="def:shebang"                 foreground="base1" bold="true"/>
  <style name="def:doc-comment-element"     italic="true"/>

  <!-- Syntax Highlighting -->
  <style name="def:constant"                foreground="cyan"/>
  <style name="def:special-char"            foreground="green"/>
  <style name="def:identifier"              foreground="blue"/>
  <style name="def:statement"               foreground="orange" bold="true"/>
  <style name="def:keyword"                 foreground="green" bold="true"/>
  <style name="def:type"                    foreground="yellow" bold="true"/>
  <style name="def:operator"                foreground="base01"/>

  <!-- Markup -->
  <style name="def:link-text"               foreground="base1"/>
  <style name="def:link-symbol"             foreground="base1" bold="true"/>
  <style name="def:link-destination"        italic="true" underline="single"/>
  <style name="def:heading"                 foreground="yellow" bold="true"/>
  <style name="def:list-marker"             foreground="orange"/>

  <!-- Others -->
  <style name="def:preprocessor"            foreground="violet"/>
  <style name="def:error"                   foreground="red" bold="true" underline="single"/>
  <style name="def:note"                    foreground="magenta" bold="true"/>
  <style name="def:net-address"             italic="true" underline="single"/>

</style-scheme>

