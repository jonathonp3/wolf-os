<?xml version="1.0" encoding="UTF-8"?>
<style-scheme id="solarized-light-lavender-blush _name="Solarized Light (Lavender Blush)" version="1.0">
  <author>Craig Russell / Jonathon</author>
  <_description>Low contrast, soft Solarized theme with pink-white background</_description>

  <!-- Solarized Palette -->
  <color name="base03"  value="#002B36"/>
  <color name="base02"  value="#073642"/>
  <color name="base01"  value="#586E75"/> <!-- Main Text (Soft Charcoal) -->
  <color name="base00"  value="#657B83"/>
  <color name="base0"   value="#839496"/>
  <color name="base1"   value="#93A1A1"/> <!-- Subtle Comments -->
  <color name="base2"   value="#EEE8D5"/> <!-- Selection/Highlight -->
  <color name="base3"   value="#FFF0F3"/> <!-- Pink-White Background -->
  
  <color name="yellow"  value="#B58900"/>
  <color name="orange"  value="#CB4B16"/>
  <color name="red"     value="#DC322F"/>
  <color name="magenta" value="#D33682"/>
  <color name="violet"  value="#6C71C4"/>
  <color name="blue"    value="#268BD2"/>
  <color name="cyan"    value="#2AA198"/>
  <color name="green"   value="#859900"/>

  <!-- Custom Blends for Softness -->
  <color name="soft-line" value="#F5E6E9"/> <!-- Slightly darker pink for current line -->

  <!-- Global Settings -->
  <style name="text"                        foreground="base01" background="base3"/>
  <style name="selection"                   background="base2"/>
  <style name="cursor"                      foreground="base01"/>
  <style name="current-line"                background="soft-line"/>
  <style name="line-numbers"                foreground="base1" background="soft-line"/>
  <style name="draw-spaces"                 foreground="base1"/>

  <!-- Bracket Matching -->
  <style name="bracket-match"               foreground="base01" background="base2" bold="false"/>
  <style name="bracket-mismatch"            foreground="red" background="base2" bold="true"/>

  <!-- Search Matching -->
  <style name="search-match"                background="base2" underline="single"/>

  <!-- Syntax: Softened by using standard Solarized colors without bolding -->
  <style name="def:comment"                 foreground="base1" italic="true"/>
  <style name="def:shebang"                 foreground="base1"/>

  <!-- Constants & Identifiers -->
  <style name="def:constant"                foreground="cyan"/>
  <style name="def:special-char"            foreground="red"/>
  <style name="def:identifier"              foreground="blue"/>
  <style name="def:type"                    foreground="yellow"/>

  <!-- Statements & Operators -->
  <style name="def:statement"               foreground="orange"/>
  <style name="def:operator"                foreground="green"/>

  <!-- Others -->
  <style name="def:preprocessor"            foreground="magenta"/>
  <style name="def:error"                   foreground="red" italic="true"/>
  <style name="def:note"                    foreground="blue" italic="true"/>
  <style name="def:net-address"             foreground="blue" underline="single"/>

</style-scheme>

