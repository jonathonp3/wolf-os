<?xml version="1.0" encoding="UTF-8"?>
<style-scheme id="kimi-dark-modern-high-contrast" _name="Kimi (High Contrast)" version="1.0">
  <author>Eliver Lara / Jonathon</author>
  <_description>High-contrast Kimi palette with deep blacks and vibrant neon accents</_description>

  <!-- High Contrast Kimi Palette -->
  <color name="kimi-bg"      value="#0d0f14"/> <!-- Deep Midnight Black -->
  <color name="kimi-fg"      value="#ffffff"/> <!-- Pure White Text -->
  <color name="kimi-line"    value="#161922"/> <!-- Subtle Current Line -->
  <color name="kimi-sel"     value="#2d313d"/> <!-- Selection -->
  
  <!-- "Electric" Kimi Accents -->
  <color name="kimi-peach"   value="#ff9e64"/> <!-- Vibrant Keywords -->
  <color name="kimi-violet"  value="#bb9af7"/> <!-- Electric Statements -->
  <color name="kimi-teal"    value="#2ac3de"/> <!-- Neon Constants -->
  <color name="kimi-cyan"    value="#7dcfff"/> <!-- Sky Identifiers -->
  <color name="kimi-blue"    value="#7aa2f7"/> <!-- Bold Operators -->
  <color name="kimi-gray"    value="#787c99"/> <!-- Brighter Comments for readability -->
  <color name="kimi-red"     value="#ff0033"/> <!-- High Contrast Red -->
  <color name="kimi-green"   value="#9ece6a"/> <!-- Matrix Green -->

  <!-- Global Settings -->
  <style name="text"                        foreground="kimi-fg" background="kimi-bg"/>
  <style name="selection"                   background="kimi-sel"/>
  <style name="cursor"                      foreground="kimi-peach"/>
  <style name="current-line"                background="kimi-line"/>
  <style name="line-numbers"                foreground="kimi-gray" background="#08090b"/>
  <style name="draw-spaces"                 foreground="#3b3f51"/>

  <!-- Syntax Highlighting -->
  <style name="def:comment"                 foreground="kimi-gray" italic="true"/>
  <style name="def:constant"                foreground="kimi-teal" bold="true"/>
  <style name="def:special-char"            foreground="kimi-peach"/>
  <style name="def:identifier"              foreground="kimi-cyan"/>
  <style name="def:function"                foreground="kimi-blue" bold="true"/>
  
  <!-- Keywords & Statements: The High Contrast Punch -->
  <style name="def:statement"               foreground="kimi-peach" bold="true"/>
  <style name="def:keyword"                 foreground="kimi-violet" bold="true"/>
  
  <style name="def:type"                    foreground="kimi-green" bold="true"/>
  <style name="def:operator"                foreground="kimi-cyan"/>
  <style name="def:preprocessor"            foreground="kimi-peach"/>
  <style name="def:error"                   foreground="kimi-red" bold="true" underline="single"/>
  <style name="def:note"                    foreground="kimi-green" bold="true"/>

  <!-- Markup -->
  <style name="def:link-text"               foreground="kimi-blue" underline="single"/>
  <style name="def:heading"                 foreground="kimi-violet" bold="true"/>
</style-scheme>

