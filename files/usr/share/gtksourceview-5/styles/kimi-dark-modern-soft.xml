<?xml version="1.0" encoding="UTF-8"?>
<style-scheme id="kimi-dark-modern-soft" _name="Kimi (Soft Modern)" version="1.0">
  <author>Eliver Lara / Jonathon</author>
  <_description>A refined, matte version of Kimi with reduced glare and softer contrast</_description>

  <!-- Softened Kimi Palette -->
  <color name="kimi-bg"      value="#1e2029"/> <!-- Deep Charcoal (Less harsh than black) -->
  <color name="kimi-fg"      value="#d1d5db"/> <!-- Soft Silver (Reduces text glare) -->
  <color name="kimi-line"    value="#282a36"/> <!-- Subtle Current Line -->
  <color name="kimi-sel"     value="#3d4451"/> <!-- Muted Selection -->
  
  <!-- "Matte" Kimi Accents (Lower Saturation) -->
  <color name="kimi-peach"   value="#e9967a"/> 
  <color name="kimi-violet"  value="#ad8ee6"/> 
  <color name="kimi-teal"    value="#70c5d3"/> 
  <color name="kimi-cyan"    value="#89ddff"/> 
  <color name="kimi-blue"    value="#82aaff"/> 
  <color name="kimi-gray"    value="#6272a4"/> <!-- Brighter Comments for clarity -->
  <color name="kimi-red"     value="#f07178"/> 
  <color name="kimi-green"   value="#95be76"/> 

  <!-- Global Settings -->
  <style name="text"                        foreground="kimi-fg" background="kimi-bg"/>
  <style name="selection"                   background="kimi-sel"/>
  <style name="cursor"                      foreground="kimi-peach"/>
  <style name="current-line"                background="kimi-line"/>
  <style name="line-numbers"                foreground="kimi-gray" background="#1a1c23"/>
  <style name="draw-spaces"                 foreground="#3b3f51"/>

  <!-- Syntax Highlighting (Bold removed from most elements to reduce "bleed") -->
  <style name="def:comment"                 foreground="kimi-gray" italic="true"/>
  <style name="def:constant"                foreground="kimi-teal"/>
  <style name="def:special-char"            foreground="kimi-peach"/>
  <style name="def:identifier"              foreground="kimi-cyan"/>
  <style name="def:function"                foreground="kimi-blue"/>
  
  <!-- Structural elements kept bold but color is softened -->
  <style name="def:statement"               foreground="kimi-peach" bold="true"/>
  <style name="def:keyword"                 foreground="kimi-violet" bold="true"/>
  
  <style name="def:type"                    foreground="kimi-green"/>
  <style name="def:operator"                foreground="kimi-cyan"/>
  <style name="def:preprocessor"            foreground="kimi-peach"/>
  <style name="def:error"                   foreground="kimi-red" bold="true" underline="single"/>
  <style name="def:note"                    foreground="kimi-green" bold="true"/>

  <!-- Markup -->
  <style name="def:link-text"               foreground="kimi-blue" underline="single"/>
  <style name="def:heading"                 foreground="kimi-violet" bold="true"/>
</style-scheme>

